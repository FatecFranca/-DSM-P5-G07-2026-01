# Database Configuration
# DATABASE_URL: Connection string for Prisma migrations
# Format: postgresql://user:password@localhost:5432/database_name
DATABASE_URL=postgresql://user:password@localhost:5432/music_selector

# DIRECT_DATABASE_URL: Direct database connection for pooling (e.g., with PgBouncer)
# This is used by the @prisma/adapter-pg for connection pooling
# If not using pooling, you can set this to the same value as DATABASE_URL
DIRECT_DATABASE_URL=postgresql://user:password@localhost:5432/music_selector

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRATION=3600

# ML Service Configuration
ML_SERVICE_URL=http://localhost:8000

# Spotify API Configuration (if applicable)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/callback

# Email Configuration (Nodemailer)
# SMTP Host
EMAIL_HOST=smtp.gmail.com
# SMTP Port (587 for TLS, 465 for SSL)
EMAIL_PORT=587
# Email account username
EMAIL_USER=your-email@gmail.com
# Email account password or app-specific password
EMAIL_PASSWORD=your-app-password
# From email address for sending emails
EMAIL_FROM=noreply@musicselector.com

# Frontend Configuration
# URL do frontend para links de reset de senha
FRONTEND_URL=http://localhost:3000

# Server Configuration
PORT=3000
NODE_ENV=development

# Seed Configuration
# When true, loads tracks and genres from src/dataset/clean_with_vibe_full.csv
SEED_DATASET=false
